{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Node",
    "composite": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist/backend",
    "rootDir": "src/backend"
  },
  "include": ["src/backend"],
  "exclude": ["src/backend/**/__tests__/*", "src/backend/**/*.test.ts"]
}
